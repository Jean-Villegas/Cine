<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Películas - CineApp</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background: rgba(255, 255, 255, 0.95);
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            text-align: center;
            margin-bottom: 30px;
        }
        .header h1 {
            color: #2c3e50;
            margin: 0;
            font-size: 2.5em;
        }
        .actions {
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            margin-bottom: 30px;
            text-align: center;
        }
        .btn {
            background: #3498db;
            color: white;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            margin: 5px;
            font-size: 1em;
            transition: background 0.3s ease;
        }
        .btn:hover {
            background: #2980b9;
        }
        .btn-success {
            background: #27ae60;
        }
        .btn-success:hover {
            background: #229954;
        }
        .btn-danger {
            background: #e74c3c;
        }
        .btn-danger:hover {
            background: #c0392b;
        }
        .movies-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .movie-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            transition: transform 0.3s ease;
        }
        .movie-card:hover {
            transform: translateY(-5px);
        }
        .movie-title {
            color: #2c3e50;
            font-size: 1.3em;
            font-weight: bold;
            margin: 0 0 10px 0;
        }
        .movie-info {
            color: #7f8c8d;
            margin: 5px 0;
        }
        .movie-info strong {
            color: #34495e;
        }
        .movie-synopsis {
            color: #7f8c8d;
            font-style: italic;
            margin: 15px 0;
            line-height: 1.5;
        }
        .movie-actions {
            margin-top: 15px;
            text-align: center;
        }
        .loading {
            text-align: center;
            color: white;
            font-size: 1.2em;
            padding: 40px;
        }
        .error {
            background: #e74c3c;
            color: white;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            margin: 20px 0;
        }
        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: rgba(255, 255, 255, 0.9);
            color: #2c3e50;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <a href="/" class="back-btn">← Volver al Inicio</a>
    
    <div class="container">
        <div class="header">
            <h1>🎭 Películas</h1>
            <p>Gestiona el catálogo de películas del cine</p>
        </div>

        <div class="actions">
            <button class="btn btn-success" onclick="loadMovies()">🔄 Cargar Películas</button>
            <a href="/peliculas/agregar" class="btn">➕ Agregar Película</a>
            <button class="btn" onclick="loadActiveMovies()">✅ Solo Activas</button>
        </div>

        <div id="moviesContainer">
            <div class="loading">
                <p>🔄 Cargando películas...</p>
                <p>Haz clic en "Cargar Películas" para ver el catálogo</p>
            </div>
        </div>
    </div>

    <script>
        const API_BASE = '/api/peliculas';

        async function loadMovies() {
            try {
                const response = await fetch(API_BASE);
                const data = await response.json();
                
                if (data.success) {
                    displayMovies(data.data);
                } else {
                    showError('Error al cargar las películas: ' + data.message);
                }
            } catch (error) {
                showError('Error de conexión: ' + error.message);
            }
        }

        async function loadActiveMovies() {
            try {
                const response = await fetch(API_BASE + '/activas');
                const data = await response.json();
                
                if (data.success) {
                    displayMovies(data.data);
                } else {
                    showError('Error al cargar las películas activas: ' + data.message);
                }
            } catch (error) {
                showError('Error de conexión: ' + error.message);
            }
        }

        function displayMovies(movies) {
            const container = document.getElementById('moviesContainer');
            
            if (movies.length === 0) {
                container.innerHTML = '<div class="error">No hay películas disponibles</div>';
                return;
            }

            container.innerHTML = `
                <div class="movies-grid">
                    ${movies.map(movie => `
                        <div class="movie-card">
                            <h3 class="movie-title">${movie.titulo}</h3>
                            <div class="movie-info"><strong>Director:</strong> ${movie.director}</div>
                            <div class="movie-info"><strong>Género:</strong> ${movie.genero}</div>
                            <div class="movie-info"><strong>Año:</strong> ${movie.año}</div>
                            <div class="movie-info"><strong>Duración:</strong> ${movie.duracion} min</div>
                            <div class="movie-info"><strong>Clasificación:</strong> ${movie.clasificacion}</div>
                            <div class="movie-info"><strong>Formato:</strong> ${movie.formato}</div>
                            <div class="movie-info"><strong>Precio:</strong> $${movie.precio}</div>
                            <div class="movie-info"><strong>Estado:</strong> ${movie.estado}</div>
                            <div class="movie-synopsis">${movie.sinopsis}</div>
                            <div class="movie-actions">
                                <a href="/peliculas/${movie.id}" class="btn">👁️ Ver Detalle</a>
                                <button class="btn" onclick="editMovie(${movie.id})">✏️ Editar</button>
                                <button class="btn btn-danger" onclick="deleteMovie(${movie.id})">🗑️ Eliminar</button>
                            </div>
                        </div>
                    `).join('')}
                </div>
            `;
        }

        function showError(message) {
            const container = document.getElementById('moviesContainer');
            container.innerHTML = `<div class="error">${message}</div>`;
        }

        async function deleteMovie(id) {
            if (confirm('¿Estás seguro de que quieres eliminar esta película?')) {
                try {
                    const response = await fetch(`${API_BASE}/${id}`, {
                        method: 'DELETE'
                    });
                    const data = await response.json();
                    
                    if (data.success) {
                        alert('Película eliminada exitosamente');
                        loadMovies(); // Recargar la lista
                    } else {
                        alert('Error al eliminar la película: ' + data.message);
                    }
                } catch (error) {
                    alert('Error al eliminar la película: ' + error.message);
                }
            }
        }

        function editMovie(id) {
            // Redirigir a formulario de edición (implementar según necesidad)
            alert('Funcionalidad de edición pendiente de implementar');
        }

        // Cargar películas al cargar la página
        window.onload = function() {
            loadMovies();
        };
    </script>
</body>
</html>